    "electron": "^33.2.0",
    "electron-vite": "^5.0.0",
    "inline-style-prefixer": "^7.0.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native-web": "^0.21.0",
    "typescript": "~5.9.2",
    "vite": "^6.0.0",
    "vite-plugin-react-native-web": "^3.1.2"
  }
